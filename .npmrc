# The dependency tree is maintained in legacy peer-deps mode (several packages
# pin React-ecosystem peers strictly). Committing this makes EVERY environment
# — host `npm install`, Dockerfile.prod `npm ci`, CI `npm ci` — resolve the
# tree the same way; without it, plain `npm ci` strict-validates peers against
# a lockfile written in legacy mode and fails with "Missing ... from lock file"
# (ADR-0022 verify finding).
legacy-peer-deps=true
