FROM node:20-alpine

# Install dumb-init for proper signal handling, curl for healthchecks, and the
# postgresql client tools (pg_dump / pg_restore) so the worker can run real
# backups (ADR-0016 Phase 2). NOTE: this base is Alpine 3.23, which does NOT ship
# a `postgresql15-client` package — the unpinned `postgresql-client` meta resolves
# to the current major (v18). A newer client dumping/restoring the postgres:15
# server is supported (pg_dump/pg_restore are backward-compatible with older
# servers), so this is safe.
RUN apk add --no-cache dumb-init curl postgresql-client

WORKDIR /app

# Copy package files first
COPY package*.json ./

# Install all dependencies (including dev dependencies for development)
# Force clean install to ensure all modules are properly installed
RUN rm -rf node_modules package-lock.json && \
    npm install --legacy-peer-deps --verbose && \
    npm cache clean --force

# Copy source code
COPY . .

# Generate Prisma client
RUN npx prisma generate

# Create necessary directories
RUN mkdir -p /app/.next /app/uploads /app/logs

# Copy and make startup script executable
COPY docker/start-dev.sh /usr/local/bin/start-dev.sh
RUN chmod +x /usr/local/bin/start-dev.sh

# Expose port
EXPOSE 3000

# Use dumb-init for proper signal handling
ENTRYPOINT ["dumb-init", "--"]

# Start the application using our startup script
CMD ["/usr/local/bin/start-dev.sh"]