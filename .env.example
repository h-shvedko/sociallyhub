# Database Configuration
DATABASE_URL="postgresql://sociallyhub:sociallyhub_dev_password@localhost:5432/sociallyhub"

# NextAuth.js Configuration
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3099"

# JWT Configuration
JWT_SECRET="your-jwt-secret-change-in-production"

# ============================================================================
# ENCRYPTION (data-at-rest: OAuth tokens & integration credentials) — ADR-0006
# ============================================================================
# REQUIRED in every mode (development, production, demo, CI). There is NO
# fallback key: if this is missing or malformed the app fails closed — crypto
# throws, docker/entrypoint.sh refuses to start, and /api/health reports
# "encryption: misconfigured".
#
# Must be 32 bytes encoded as exactly 64 hex characters. Generate with:
#   openssl rand -hex 32
#
# BACK THIS UP in your password manager at generation time. Losing it makes
# every encrypted column (social tokens, integration credentials) permanently
# unreadable — recovery means users reconnect accounts / re-enter credentials.
ENCRYPTION_KEY="your_64_hex_char_encryption_key_here"

# Optional. Decrypt-only key used ONLY during key rotation. To rotate: set this
# to the CURRENT (old) key, set ENCRYPTION_KEY to a NEW key, deploy, run the
# rotation script to re-encrypt, then remove this line once no ciphertext still
# references the old key. Same format (64 hex chars).
# ENCRYPTION_KEY_PREVIOUS="your_previous_64_hex_char_key_here"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Environment
NODE_ENV="development"

# ============================================================================
# SOCIAL MEDIA API KEYS
# ============================================================================
# Get these from the respective developer portals and add your keys below

# Twitter/X API v2
# Get from: https://developer.twitter.com/
TWITTER_CLIENT_ID="your_twitter_client_id"
TWITTER_CLIENT_SECRET="your_twitter_client_secret"

# Facebook/Meta API
# Get from: https://developers.facebook.com/
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# Meta Graph webhooks (Facebook Pages + Instagram) — /api/webhooks/meta (ADR-0009)
# META_APP_SECRET: the Meta App Secret used to sign webhook deliveries. Required
#   to accept POSTs — the receiver verifies X-Hub-Signature-256 against it and
#   rejects everything (503) until it is set. Usually equals FACEBOOK_APP_SECRET
#   (the App Secret is shared across the app's products).
META_APP_SECRET="your_meta_app_secret"
# META_WEBHOOK_VERIFY_TOKEN: an arbitrary secret string YOU invent, entered
#   identically in the Meta App Dashboard webhook config. Meta echoes it on the
#   GET verification handshake; the receiver only completes the handshake when it
#   matches. Generate one, e.g.: openssl rand -hex 32
META_WEBHOOK_VERIFY_TOKEN="your_meta_webhook_verify_token"

# Instagram Basic Display API (via Facebook)
# Get from: https://developers.facebook.com/docs/instagram-basic-display-api
# INSTAGRAM_APP_ID="your_instagram_app_id"
# INSTAGRAM_APP_SECRET="your_instagram_app_secret"

# LinkedIn API v2
# Get from: https://developer.linkedin.com/
# LINKEDIN_CLIENT_ID="your_linkedin_client_id"
# LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"

# TikTok for Developers
# Get from: https://developers.tiktok.com/
# TIKTOK_CLIENT_KEY="your_tiktok_client_key"
# TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"

# YouTube Data API v3 (via Google)
# Get from: https://console.developers.google.com/
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"
# YOUTUBE_API_KEY="your_youtube_api_key"

# ============================================================================
# AI SERVICES
# ============================================================================

# OpenAI API for AI Features
# Get from: https://platform.openai.com/api-keys
# Required for: Content generation, hashtag suggestions, tone analysis, performance predictions
OPENAI_API_KEY="your-openai-api-key-here"

# Optional: Other AI Providers (future implementation)
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# GOOGLE_AI_API_KEY="your-google-ai-api-key"
# AZURE_OPENAI_API_KEY="your-azure-openai-api-key"

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# SMTP Configuration for Production
# For development, uses Mailhog (configured in docker-compose.yml)
SMTP_HOST="your-smtp-host"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"
SMTP_SECURE="true"

# Development Email Testing (Mailhog)
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@sociallyhub.dev"
# SMTP_SECURE="false"

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Development Features
ENABLE_DEMO="true"

# Optional: Feature toggles
# ENABLE_AI_FEATURES="true"
# ENABLE_ANALYTICS="true"
# ENABLE_BULK_UPLOAD="true"
# ENABLE_WHITE_LABEL="false"

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# Analytics and Monitoring
# GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"
# MIXPANEL_TOKEN="your-mixpanel-token"
# SENTRY_DSN="your-sentry-dsn"

# ============================================================================
# FILE STORAGE (ADR-0007)
# ============================================================================
# All uploads (workspace media, support attachments, help content) flow through
# the storage service in src/lib/storage. Select the backing driver here.

# local | s3 — the local-disk driver is the default and only wired driver; the
# S3/MinIO-compatible driver is wired in ADR-0022 (production flips to s3 once
# the MinIO service lands in docker-compose.prod.yml).
STORAGE_DRIVER="local"

# Root directory for the local driver. Default: ./uploads (relative to cwd).
# In production this path is a mounted volume (docker-compose.prod.yml mounts
# uploads:/app/uploads) so uploads survive redeploys.
STORAGE_LOCAL_ROOT="./uploads"

# S3/MinIO driver settings (ADR-0022 — not read until STORAGE_DRIVER=s3):
# S3_ENDPOINT="http://minio:9000"
# S3_BUCKET="sociallyhub"
# S3_ACCESS_KEY="your-s3-access-key"
# S3_SECRET_KEY="your-s3-secret-key"

# CDN Configuration
# CDN_URL="https://cdn.yourdomain.com"

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================

# Rate Limiting
# RATE_LIMIT_REQUESTS_PER_MINUTE="100"
# RATE_LIMIT_REQUESTS_PER_HOUR="1000"

# CORS Configuration
# ALLOWED_ORIGINS="http://localhost:3099,https://yourdomain.com"

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Debug Modes
# DEBUG_SQL="false"
# DEBUG_API="false"
# LOG_LEVEL="info"

# Development Tools
# ENABLE_PRISMA_STUDIO="true"
# ENABLE_API_DOCS="true"

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================

# Domain Configuration
# DOMAIN="yourdomain.com"
# SUBDOMAIN="app"
# FULL_URL="https://app.yourdomain.com"

# SSL/Security
# SSL_CERT_PATH="/path/to/ssl/cert"
# SSL_KEY_PATH="/path/to/ssl/key"

# Backup Configuration
# BACKUP_S3_BUCKET="your-backup-bucket"
# BACKUP_FREQUENCY="daily"

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env.local for development
# 2. Never commit .env.local to version control
# 3. For production, use environment variables or secure secret management
# 4. Some services require webhooks - configure them in your provider dashboards
# 5. OpenAI API key is required for AI features to work properly
# 6. Without API keys, the app will use mock providers for development