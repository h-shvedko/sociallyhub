# Database Configuration
DATABASE_URL="postgresql://sociallyhub:sociallyhub_dev_password@localhost:5432/sociallyhub"

# NextAuth.js Configuration
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3099"

# JWT Configuration
JWT_SECRET="your-jwt-secret-change-in-production"

# ============================================================================
# ENCRYPTION (data-at-rest: OAuth tokens & integration credentials) — ADR-0006
# ============================================================================
# REQUIRED in every mode (development, production, demo, CI). There is NO
# fallback key: if this is missing or malformed the app fails closed — crypto
# throws, docker/entrypoint.sh refuses to start, and /api/health reports
# "encryption: misconfigured".
#
# Must be 32 bytes encoded as exactly 64 hex characters. Generate with:
#   openssl rand -hex 32
#
# BACK THIS UP in your password manager at generation time. Losing it makes
# every encrypted column (social tokens, integration credentials) permanently
# unreadable — recovery means users reconnect accounts / re-enter credentials.
ENCRYPTION_KEY="your_64_hex_char_encryption_key_here"

# Optional. Decrypt-only key used ONLY during key rotation. To rotate: set this
# to the CURRENT (old) key, set ENCRYPTION_KEY to a NEW key, deploy, run the
# rotation script to re-encrypt, then remove this line once no ciphertext still
# references the old key. Same format (64 hex chars).
# ENCRYPTION_KEY_PREVIOUS="your_previous_64_hex_char_key_here"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Environment
NODE_ENV="development"

# ============================================================================
# SOCIAL MEDIA API KEYS
# ============================================================================
# Get these from the respective developer portals and add your keys below

# Twitter/X API v2
# Get from: https://developer.twitter.com/
TWITTER_CLIENT_ID="your_twitter_client_id"
TWITTER_CLIENT_SECRET="your_twitter_client_secret"

# Facebook/Meta API
# Get from: https://developers.facebook.com/
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# Meta Graph webhooks (Facebook Pages + Instagram) — /api/webhooks/meta (ADR-0009)
# META_APP_SECRET: the Meta App Secret used to sign webhook deliveries. Required
#   to accept POSTs — the receiver verifies X-Hub-Signature-256 against it and
#   rejects everything (503) until it is set. Usually equals FACEBOOK_APP_SECRET
#   (the App Secret is shared across the app's products).
META_APP_SECRET="your_meta_app_secret"
# META_WEBHOOK_VERIFY_TOKEN: an arbitrary secret string YOU invent, entered
#   identically in the Meta App Dashboard webhook config. Meta echoes it on the
#   GET verification handshake; the receiver only completes the handshake when it
#   matches. Generate one, e.g.: openssl rand -hex 32
META_WEBHOOK_VERIFY_TOKEN="your_meta_webhook_verify_token"

# Instagram Basic Display API (via Facebook)
# Get from: https://developers.facebook.com/docs/instagram-basic-display-api
# INSTAGRAM_APP_ID="your_instagram_app_id"
# INSTAGRAM_APP_SECRET="your_instagram_app_secret"

# LinkedIn API v2
# Get from: https://developer.linkedin.com/
# LINKEDIN_CLIENT_ID="your_linkedin_client_id"
# LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"

# TikTok for Developers
# Get from: https://developers.tiktok.com/
# TIKTOK_CLIENT_KEY="your_tiktok_client_key"
# TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"

# YouTube Data API v3 (via Google)
# Get from: https://console.developers.google.com/
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"
# YOUTUBE_API_KEY="your_youtube_api_key"

# ============================================================================
# AI SERVICES
# ============================================================================

# OpenAI API for AI Features
# Get from: https://platform.openai.com/api-keys
# Required for: Content generation, hashtag suggestions, tone analysis, performance predictions
#
# Three-state behavior (ADR-0018, gated by DEMO_MODE per ADR-0025):
# - Real key set                     -> real OpenAI provider
# - No key + demo mode (DEMO_MODE=true)
#                                    -> mock provider; responses are labeled
#                                       { aiProvider: "mock", simulated: true }
# - No key + not demo (default, incl. production)
#                                    -> AI routes return an honest
#                                       503 AI_UNAVAILABLE (no fabricated output)
# The literal placeholder value below counts as "no key".
OPENAI_API_KEY="your-openai-api-key-here"

# Optional: model overrides (defaults shown). Applies to all AI features.
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_VISION_MODEL="gpt-4o-mini"

# Optional: workspace monthly AI spend backstop, in CENTS (default: OFF when
# unset). When set > 0, AI calls fail with 429 AI_QUOTA_EXCEEDED once a
# workspace's tracked AI cost for the current calendar month reaches this
# ceiling. Plan-tier AI credit limits (ADR-0019) remain the primary control.
# AI_MONTHLY_COST_LIMIT_CENTS="500"

# Optional: Other AI Providers (future implementation)
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# GOOGLE_AI_API_KEY="your-google-ai-api-key"
# AZURE_OPENAI_API_KEY="your-azure-openai-api-key"

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# SMTP Configuration for Production
# For development, uses Mailhog (configured in docker-compose.yml)
SMTP_HOST="your-smtp-host"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"
SMTP_SECURE="true"

# Development Email Testing (Mailhog)
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@sociallyhub.dev"
# SMTP_SECURE="false"

# ============================================================================
# WEB PUSH (browser push notifications) — ADR-0010 Phase 4
# ============================================================================
# VAPID keypair used to sign Web Push messages. When these are unset the push
# channel is a HONEST no-op: subscriptions can still be stored, but no push is
# ever sent (the dispatch worker logs and skips — it never fabricates delivery).
#
# Generate a fresh keypair with:
#   npx web-push generate-vapid-keys
#
# VAPID_EMAIL is the "mailto:" contact required by the Web Push spec; push
# services use it to reach you about your pushes. Must start with "mailto:".
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:noreply@yourdomain.com"

# ============================================================================
# DEMO MODE & SEEDING (ADR-0025)
# ============================================================================
# DEMO_MODE is the ONE switch that turns on every demo-only behavior — the
# signin/setup credential hints, the fabricated /api/accounts/connect account,
# the mock AI provider, and the `demo` seed tier. The full enumerated registry
# lives in docs/demo-mode.md.
#
#   - UNSET / "false" (default, and the ONLY safe value in production):
#     demo is OFF everywhere, INCLUDING local dev. Nothing is fabricated.
#   - "true": enables the showcase. Set this ONLY for the demo deployment (the
#     dev docker-compose already sets it for you). NEVER set it in production.
#
# There is no NODE_ENV heuristic and no ENABLE_DEMO backdoor anymore — both were
# removed. A bare `next dev` without DEMO_MODE=true shows an empty, honest app.
DEMO_MODE="false"

# Which seed tier `prisma/seed.ts` runs (also selectable via --tier=<t> argv).
#   - minimal (default): prod-safe, idempotent — settings defaults + the first
#     platform admin only. Safe on every boot; wipes nothing.
#   - demo:    the full showcase dataset. REQUIRES DEMO_MODE=true or it aborts;
#              its destructive reset additionally requires an explicit --wipe.
#   - test:    deterministic CI fixtures (fixed ids, seeded PRNG, small volume).
SEED_TIER="minimal"

# Demo user password (ADR-0025 D4). Read by BOTH the demo seed (to create
# demo@sociallyhub.com) and the signin/setup credential hint — never a committed
# constant. When unset, the demo seed generates one and prints it once. The dev
# docker-compose sets this to a known dev value for the showcase.
# DEMO_USER_PASSWORD=""

# First platform-admin bootstrap (ADR-0025 D4, ADR-0004/0012). The minimal seed
# grants User.isPlatformAdmin to every email in this comma-separated allowlist,
# creating the account when none exists. If it is SET but yields zero admins the
# seed FAILS loudly; if UNSET on a fresh DB it warns and points at
# scripts/grant-platform-admin.ts (boot is not bricked).
# PLATFORM_ADMIN_EMAILS="you@example.com"

# Optional password for a freshly CREATED seeded platform admin. When unset a
# strong random password is generated and printed ONCE at seed time (change it
# on first login). Never a committed constant.
# ADMIN_INITIAL_PASSWORD=""

# E2E/CI test-user password (ADR-0025 D4). The `test` seed tier and
# e2e/global-setup.ts read the SAME variable; supplied via CI env, not source.
# E2E_USER_PASSWORD=""

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# ----------------------------------------------------------------------------
# Deferred subsystems (ADR-0013 / ADR-0014 / ADR-0015)
# ----------------------------------------------------------------------------
# These three subsystems are DEFERRED and KNOWN-BROKEN. They are gated off by
# `src/middleware.ts` (which 404s their `/api/**` routes) and by their UI entry
# points. Read once from env by `src/lib/config/features.ts`. Each flag is
# `=== 'true'` and defaults to false when unset.
#
# KEEP ALL THREE FALSE IN PRODUCTION until their repair phases ship
# (ADR-0013 Phase 3 / ADR-0014 Phase 3 / ADR-0015 Phase 3+). Flipping any of
# them on re-exposes broken, unsupported endpoints. Do not set them in the
# production deployment config.
#
# FEATURE_DISCORD is a SUB-FLAG of FEATURE_COMMUNITY: Discord routes live under
# `/api/community/**`, so Discord is effectively enabled only when BOTH
# FEATURE_DISCORD and FEATURE_COMMUNITY are true.
FEATURE_COMMUNITY="false"
FEATURE_DOCS_MANAGEMENT="false"
FEATURE_DISCORD="false"
#
# Client-side (build-time) mirrors used by help-center.tsx to hide the UI entry
# points (community/docs buttons, Documentation card). At un-deferral, set BOTH
# the server FEATURE_* var and its NEXT_PUBLIC_ mirror (Next.js only exposes
# NEXT_PUBLIC_-prefixed vars to client components, and inlines them at build).
NEXT_PUBLIC_FEATURE_COMMUNITY="false"
NEXT_PUBLIC_FEATURE_DOCS_MANAGEMENT="false"

# Optional: Feature toggles
# ENABLE_AI_FEATURES="true"
# ENABLE_ANALYTICS="true"
# ENABLE_BULK_UPLOAD="true"
# ENABLE_WHITE_LABEL="false"

# ============================================================================
# BILLING — STRIPE (ADR-0019)
# ============================================================================
# Wired (ADR-0019 Track A): /api/billing/checkout|portal|webhook|subscription.
# Use test-mode keys (sk_test_/whsec_) in dev. There is NO mock fallback:
# without STRIPE_SECRET_KEY the checkout/portal routes return
# 503 { error: 'stripe_not_configured' } and the UI says so plainly.
# STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
# STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_signing_secret"
# Monthly recurring Price ids from your Stripe dashboard (price_...). These
# map Stripe prices to local plan tiers; unknown price ids are never guessed.
# STRIPE_PRICE_PRO_MONTHLY="price_your_pro_monthly_price_id"
# STRIPE_PRICE_BUSINESS_MONTHLY="price_your_business_monthly_price_id"
# Public app URL for Stripe checkout/portal redirects. Optional — falls back
# to NEXTAUTH_URL when unset.
# NEXT_PUBLIC_APP_URL="http://localhost:3099"

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# Analytics and Monitoring
# GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"
# MIXPANEL_TOKEN="your-mixpanel-token"
# SENTRY_DSN="your-sentry-dsn"

# ============================================================================
# FILE STORAGE (ADR-0007)
# ============================================================================
# All uploads (workspace media, support attachments, help content) flow through
# the storage service in src/lib/storage. Select the backing driver here.

# local | s3 — the local-disk driver is the default and only wired driver; the
# S3/MinIO-compatible driver is wired in ADR-0022 (production flips to s3 once
# the MinIO service lands in docker-compose.prod.yml).
STORAGE_DRIVER="local"

# Root directory for the local driver. Default: ./uploads (relative to cwd).
# In production this path is a mounted volume (docker-compose.prod.yml mounts
# uploads:/app/uploads) so uploads survive redeploys.
STORAGE_LOCAL_ROOT="./uploads"

# S3/MinIO driver settings (ADR-0022 — not read until STORAGE_DRIVER=s3):
# S3_ENDPOINT="http://minio:9000"
# S3_BUCKET="sociallyhub"
# S3_ACCESS_KEY="your-s3-access-key"
# S3_SECRET_KEY="your-s3-secret-key"

# CDN Configuration
# CDN_URL="https://cdn.yourdomain.com"

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================

# Cron authentication (ADR-0005): shared secret that authorizes cron-scope
# endpoints (e.g. scheduled report runs). Callers send it as the
# `x-cron-secret` header; withApiAuth's 'cron' scope compares it to this var
# and rejects everything when it is unset. Generate: openssl rand -hex 32
CRON_SECRET="your_cron_secret_here"

# Rate Limiting
# RATE_LIMIT_REQUESTS_PER_MINUTE="100"
# RATE_LIMIT_REQUESTS_PER_HOUR="1000"

# CORS Configuration
# ALLOWED_ORIGINS="http://localhost:3099,https://yourdomain.com"

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Debug Modes
# DEBUG_SQL="false"
# DEBUG_API="false"
# LOG_LEVEL="info"

# Development Tools
# ENABLE_PRISMA_STUDIO="true"
# ENABLE_API_DOCS="true"

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================

# Domain Configuration
# DOMAIN="yourdomain.com"
# SUBDOMAIN="app"
# FULL_URL="https://app.yourdomain.com"

# SSL/Security
# SSL_CERT_PATH="/path/to/ssl/cert"
# SSL_KEY_PATH="/path/to/ssl/key"

# Backup Configuration (ADR-0016)
# Directory where the backup worker writes pg_dump/tar artifacts. Defaults to
# /app/backups in code; docker-compose (dev and prod) sets it explicitly and
# mounts a shared `backups` volume there so app + worker see the same files.
# Uncomment to override for bare-metal/local runs.
# BACKUP_DIR="/app/backups"
# BACKUP_S3_BUCKET="your-backup-bucket"
# BACKUP_FREQUENCY="daily"

# ============================================================================
# OBSERVABILITY & MONITORING (ADR-0023)
# ============================================================================
# The self-hosted metrics/logging/error-tracking stack. In local dev NONE of
# these are required — leave them unset and the app behaves exactly as before
# (metrics endpoint open, file logging, Sentry/GlitchTip dormant). They matter
# in the production docker-compose (docker-compose.prod.yml), which sets safe
# defaults for most of them.

# Bearer token that protects the Prometheus scrape endpoint /api/metrics.
#   - UNSET (default): the endpoint is OPEN. Fine in dev and on the
#     compose-internal network (nginx never proxies /api/metrics publicly).
#   - SET: /api/metrics requires `Authorization: Bearer <METRICS_TOKEN>`.
#     Prometheus does NOT expand env vars in its config, so to actually enforce
#     it you also write the same value to a file and point the scrape job at it
#     via `authorization.credentials_file` (see docker/monitoring/prometheus.yml).
#   Generate: openssl rand -hex 32
# METRICS_TOKEN=""

# Winston logging mode.
#   - "true" (default in prod compose): JSON to STDOUT ONLY — no in-container
#     log files — so Promtail/Loki can scrape the Docker json logs.
#   - unset / anything else (local dev default): the original file transports
#     under ./logs plus a colorized console.
# LOG_TO_STDOUT="true"

# Worker heartbeat expectation for /api/health.
#   - "true" (default in prod compose, where the worker container always runs):
#     health asserts the `worker:heartbeat` Redis key is fresh.
#   - unset/false: the worker check reports "disabled" and health stays green
#     even without a worker (useful for app-only local runs).
# WORKER_EXPECTED="true"

# ---- Error tracking: @sentry/nextjs -> self-hosted GlitchTip (Sentry protocol)
# SENTRY_DSN is the ONLY switch: empty (default) = error tracking is completely
# DORMANT (guarded dynamic import, zero runtime cost, no build changes). Set it
# to a project DSN (from your GlitchTip UI, or Sentry SaaS) to start reporting.
# SENTRY_DSN=""
# Fraction of transactions traced for performance (0 = off, the honest default).
# SENTRY_TRACES_SAMPLE_RATE="0"

# ---- Grafana (monitoring compose profile) admin password. Defaults to "admin"
# in docker-compose.prod.yml — CHANGE IT for any real deploy.
# GRAFANA_PASSWORD="admin"

# ---- GlitchTip self-hosted (docker-compose.prod.yml `glitchtip` profile).
# OPT-IN and dormant until set up: needs a created `glitchtip` Postgres DB, a
# SECRET_KEY, and a project DSN copied into SENTRY_DSN above. See the loud
# runbook comment above the glitchtip service in docker-compose.prod.yml.
# GLITCHTIP_SECRET_KEY=""                        # openssl rand -hex 32 (REQUIRED to boot)
# GLITCHTIP_DOMAIN="http://localhost:8080"       # external URL of the GlitchTip UI
# GLITCHTIP_FROM_EMAIL="glitchtip@localhost"
# GLITCHTIP_EMAIL_URL="consolemail://"           # e.g. smtp://user:pass@host:587
# GLITCHTIP_CELERY_AUTOSCALE="1,3"

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env.local for development
# 2. Never commit .env.local to version control
# 3. For production, use environment variables or secure secret management
# 4. Some services require webhooks - configure them in your provider dashboards
# 5. OpenAI API key is required for AI features to work properly
# 6. Without API keys, AI is unavailable (503) unless DEMO_MODE=true, which
#    enables the labeled mock provider — see docs/demo-mode.md (ADR-0025)