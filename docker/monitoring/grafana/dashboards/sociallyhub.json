      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"sociallyhub-app\"}",
          "legendFormat": "app"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total requests (rate 5m)",
      "description": "sum(rate(http_requests_total[5m])).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
